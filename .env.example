NODE_ENV=production
PORT=4173
PUBLIC_APP_URL=https://your-domain.com
PERSISTENCE=prisma

# Initial admin account. Change before production.
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
TEXT_MODEL=gpt-5.5
IMAGE_MODEL=gpt-image-2

# Stripe subscription checkout
STRIPE_SECRET_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# OAuth placeholders
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Production database
POSTGRES_USER=sellercanvas
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=sellercanvas
DATABASE_URL=postgresql://sellercanvas:sellercanvas@postgres:5432/sellercanvas

# Redis queue
REDIS_URL=redis://redis:6379

# Object storage
STORAGE_PROVIDER=r2
STORAGE_BUCKET=sellercanvas-assets
STORAGE_PUBLIC_BASE_URL=https://assets.your-domain.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Stripe webhooks
STRIPE_WEBHOOK_SECRET=

# Internal worker authentication
WORKER_INTERNAL_SECRET=change-this-worker-secret
